<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>기후 학습 앱</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        #map { height: 400px; width: 100%; border-radius: 12px; z-index: 1; }
        .chart-container { position: relative; height: 300px; width: 100%; }
    </style>
</head>
<body class="bg-gray-900 text-white p-4">
    <div class="max-w-4xl mx-auto">
        <header class="text-center mb-6">
            <h1 class="text-3xl font-bold text-blue-400">🌍 기후 시각화 도구</h1>
        </header>
        <div id="map" class="mb-6 shadow-2xl border border-gray-700"></div>
        <div id="info-panel" class="bg-gray-800 p-6 rounded-xl border border-gray-700 hidden">
            <h2 id="city-name" class="text-2xl font-bold mb-4 text-yellow-400">도시 이름</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="chart-container"><canvas id="climateChart"></canvas></div>
                <div class="text-gray-300">
                    <h3 class="font-bold text-lg mb-2 underline">기후 특징</h3>
                    <p id="climate-desc"></p>
                </div>
            </div>
        </div>
    </div>
    <script>
        const climateData = {
            "Seoul": { coords: [37.56, 126.97], temp: [-2,0,6,13,18,22,25,26,21,15,7,0], precip: [20,25,47,64,102,133,394,364,169,51,52,21], desc: "냉대 기후(Dwa). 여름은 고온다습하고 겨울은 한랭건조합니다." },
            "London": { coords: [51.50, -0.12], temp: [5,5,8,10,14,17,19,19,17,13,9,6], precip: [55,40,42,43,46,45,45,49,49,68,59,55], desc: "서안 해양성 기후(Cfb). 연중 강수가 고르고 여름이 선선합니다." },
            "Singapore": { coords: [1.35, 103.81], temp: [26,27,27,28,28,28,28,28,27,27,27,26], precip: [234,183,185,179,171,130,154,148,163,191,250,269], desc: "열대 우림 기후(Af). 연중 고온다습하며 스콜이 자주 내립니다." }
        };

        const map = L.map('map').setView([20, 20], 2);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

        let myChart;

        Object.keys(climateData).forEach(city => {
            const data = climateData[city];
            L.marker(data.coords).addTo(map).on('click', () => {
                document.getElementById('info-panel').classList.remove('hidden');
                document.getElementById('city-name').innerText = city;
                document.getElementById('climate-desc').innerText = data.desc;
                const ctx = document.getElementById('climateChart').getContext('2d');
                if (myChart) myChart.destroy();
                myChart = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: ['1월','2월','3월','4월','5월','6월','7월','8월','9월','10월','11월','12월'],
                        datasets: [
                            { label: '기온(°C)', data: data.temp, type: 'line', borderColor: '#ff6384', yAxisID: 'y-temp' },
                            { label: '강수량(mm)', data: data.precip, backgroundColor: '#36a2eb', yAxisID: 'y-precip' }
                        ]
                    },
                    options: { scales: { 'y-temp': { position: 'left' }, 'y-precip': { position: 'right' } } }
                });
            });
        });
    </script>
</body>
</html>
